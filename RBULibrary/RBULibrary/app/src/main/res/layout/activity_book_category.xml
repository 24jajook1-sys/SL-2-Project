<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A237E"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Book Categories"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select a category to browse books"
                android:textSize="13sp"
                android:textColor="#B3C5FF"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Category Buttons -->
        <Button
            android:id="@+id/btnNovel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="📖  Novel"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#283593"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnAutobiography"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="👤  Autobiography"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnEngineering"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="⚙️  Engineering College"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#00695C"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnNeet"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="🩺  NEET Books"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnJee"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="🔬  JEE Books"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4A148C"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnMotivational"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="🌟  Motivational"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#E65100"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Each category has 10 books available"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>
    </LinearLayout>
</ScrollView>
