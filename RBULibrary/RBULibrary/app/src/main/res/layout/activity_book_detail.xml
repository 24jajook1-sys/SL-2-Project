<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Book Detail Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/imgBookDetail"
                    android:layout_width="100dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_book"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Book Title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Author"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:gravity="center"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="#1A237E"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEEEE" android:layout_marginVertical="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About this Book"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Book Register Form -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 Book Register"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Your Name *" android:textStyle="bold" android:textColor="#333333"
                    android:textSize="13sp" android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/etBorrowerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your full name"
                    android:background="@android:drawable/edit_text"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Date of Taking *" android:textStyle="bold" android:textColor="#333333"
                    android:textSize="13sp" android:layout_marginBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="14dp">
                    <EditText
                        android:id="@+id/etTakeDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="dd/mm/yyyy"
                        android:background="@android:drawable/edit_text"
                        android:padding="10dp"
                        android:focusable="false"
                        android:editable="false"/>
                    <Button
                        android:id="@+id/btnPickTakeDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:backgroundTint="#1A237E"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Date of Returning *" android:textStyle="bold" android:textColor="#333333"
                    android:textSize="13sp" android:layout_marginBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="20dp">
                    <EditText
                        android:id="@+id/etReturnDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="dd/mm/yyyy"
                        android:background="@android:drawable/edit_text"
                        android:padding="10dp"
                        android:focusable="false"
                        android:editable="false"/>
                    <Button
                        android:id="@+id/btnPickReturnDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:backgroundTint="#1A237E"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBookRegister"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="SUBMIT &amp; GET RECEIPT"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:backgroundTint="#1A237E"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
