<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!--  Header  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A237E"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Registration"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RBU Library System"
                android:textSize="13sp"
                android:textColor="#B3C5FF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!--  Form Card  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter your full name"
                android:inputType="textPersonName"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="College Email ID *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 24paliwalk_1@rbunagpur.in"
                android:inputType="textEmailAddress"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Must be @rbunagpur.in email"
                android:textSize="11sp"
                android:textColor="#E53935"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Branch *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerBranch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_default"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Section *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSection"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_default"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Year *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerYear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_default"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number *"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="10-digit mobile number"
                android:inputType="phone"
                android:maxLength="10"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SUBMIT &amp; BROWSE BOOKS"
                android:textStyle="bold"
                android:textSize="14sp"
                android:backgroundTint="#1A237E"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
